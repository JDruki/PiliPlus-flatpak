<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.example.piliplus</id>
  <name>PiliPlus</name>
  <summary>A third-party Bilibili client developed in Flutter</summary>
  <summary xml:lang="zh-CN">使用 Flutter 开发的 Bilibili 第三方客户端</summary>
  <developer id="com.example">
    <name>PiliPlus contributors</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  <url type="homepage">https://github.com/bggRGjQaUbCoE/PiliPlus</url>
  <url type="bugtracker">https://github.com/bggRGjQaUbCoE/PiliPlus/issues</url>
  <launchable type="desktop-id">com.example.piliplus.desktop</launchable>
  <description>
    <p>PiliPlus is an unofficial desktop client for browsing and playing Bilibili content. It is built with Flutter and packages the upstream Linux release for desktop use.</p>
    <p xml:lang="zh-CN">PiliPlus 是一个用于浏览和播放 Bilibili 内容的第三方桌面客户端。它使用 Flutter 构建，并封装上游 Linux 发布版本以便桌面使用。</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/bggRGjQaUbCoE/PiliPlus/main/assets/screenshots/main_screen.png</image>
      <caption>Main application window</caption>
      <caption xml:lang="zh-CN">应用主窗口</caption>
    </screenshot>
  </screenshots>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="@VERSION@" date="@RELEASE_DATE@">
      <description>
        <p>Upstream PiliPlus @VERSION@ release.</p>
      </description>
    </release>
  </releases>
</component>
